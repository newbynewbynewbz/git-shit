#!/bin/bash
# Git Shit: Pre-push hook
# Blocks direct pushes to protected branches — forces PR workflow
# Bypass: git push --no-verify (emergencies only)

# --- Config + libs ---
_gs_root="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -f "$_gs_root/.gitshitrc" ] && bash -n "$_gs_root/.gitshitrc" 2>/dev/null && . "$_gs_root/.gitshitrc"
for _d in "$_gs_root/scripts/lib" "$_gs_root/lib"; do
  [ -f "$_d/profile.sh" ] && . "$_d/profile.sh"
  [ -f "$_d/output.sh" ] && . "$_d/output.sh"
done
type gs_teach >/dev/null 2>&1 || gs_teach() { [ "${TEACH_MODE:-off}" = "on" ] && printf '%s\n' "$@"; }

PROTECTED_BRANCHES="${GIT_SHIT_PROTECTED_BRANCHES:-${PROTECTED_BRANCHES:-main}}"
BRANCH_PATTERN="${GIT_SHIT_BRANCH_PATTERN:-${BRANCH_PATTERN:-}}"
BRANCH_NAMING_MODE="${GIT_SHIT_BRANCH_NAMING_MODE:-${BRANCH_NAMING_MODE:-off}}"

# --- Branch naming check ---
if [ "$BRANCH_NAMING_MODE" != "off" ] && [ -n "$BRANCH_PATTERN" ]; then
  CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
  if [ -n "$CURRENT_BRANCH" ]; then
    IS_PROTECTED=false
    IFS='|' read -ra _PROT_LIST <<< "$PROTECTED_BRANCHES"
    for _pb in "${_PROT_LIST[@]}"; do
      [ "$CURRENT_BRANCH" = "$_pb" ] && IS_PROTECTED=true && break
    done

    if [ "$IS_PROTECTED" = "false" ] && ! [[ "$CURRENT_BRANCH" =~ $BRANCH_PATTERN ]]; then
      echo ""
      if [ "$BRANCH_NAMING_MODE" = "strict" ]; then
        echo "🛑 Branch name rejected: $CURRENT_BRANCH"
      else
        echo "💡 Branch naming suggestion for: $CURRENT_BRANCH"
      fi
      echo ""
      gs_teach "  Expected pattern: <type>/<description>" \
               "  Types: feat fix refactor docs test chore style perf ci build revert research" \
               "" \
               "  Examples:" \
               "    feat/add-login" \
               "    fix/null-pointer-crash" \
               "    docs/update-readme" \
               ""
      if [ "$BRANCH_NAMING_MODE" = "strict" ]; then
        echo "  Rename your branch:"
        echo "    git branch -m $CURRENT_BRANCH feat/your-description"
        echo ""
        exit 1
      fi
    fi
  fi
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  IFS='|' read -ra BRANCHES <<< "$PROTECTED_BRANCHES"
  for PROTECTED in "${BRANCHES[@]}"; do
    if [ "$remote_ref" = "refs/heads/$PROTECTED" ]; then
      # Allow initial push to create the remote branch
      [ "$remote_sha" = "0000000000000000000000000000000000000000" ] && continue
      echo ""
      echo "🛑 Direct push to $PROTECTED blocked"
      echo ""
      echo "  Use the PR workflow instead:"
      echo "    1. git checkout -b feat/my-change"
      echo "    2. git push -u origin feat/my-change"
      echo "    3. gh pr create --fill"
      echo "    4. gh pr merge --squash --delete-branch"
      echo ""
      gs_teach "  Already committed to $PROTECTED by accident?" \
               "    git reset --soft HEAD~     # undo commit, keep changes staged" \
               "    git checkout -b feat/x     # move to a new branch" \
               "    git push -u origin feat/x" \
               ""
      echo "  Emergency bypass: git push --no-verify"
      echo ""
      exit 1
    fi
  done
done

exit 0
