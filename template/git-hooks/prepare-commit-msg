#!/bin/bash
# Git Shit: prepare-commit-msg hook
# Pre-fills conventional commit prefix from branch name.
# No-op when COMMIT_MSG_MODE=off (solo profile default).

# --- Config + libs ---
_gs_root="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -f "$_gs_root/.gitshitrc" ] && bash -n "$_gs_root/.gitshitrc" 2>/dev/null && . "$_gs_root/.gitshitrc"
for _d in "$_gs_root/scripts/lib" "$_gs_root/lib"; do
  [ -f "$_d/profile.sh" ] && . "$_d/profile.sh"
done

COMMIT_MSG_MODE="${GIT_SHIT_COMMIT_MSG:-${COMMIT_MSG_MODE:-off}}"
# If conventional commits aren't enforced, don't auto-prefill either.
[ "$COMMIT_MSG_MODE" = "off" ] && exit 0

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Only auto-fill for new commits (not merges, amends, squashes, etc.)
[ -n "$COMMIT_SOURCE" ] && exit 0

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

TYPE=$(echo "$BRANCH" | sed -n 's|^\(feat\|fix\|refactor\|docs\|test\|chore\|style\|perf\|ci\|build\|revert\)/.*|\1|p')
SCOPE=$(echo "$BRANCH" | sed -n 's|^\(feat\|fix\|refactor\|docs\|test\|chore\|style\|perf\|ci\|build\|revert\)/\([a-zA-Z0-9_-]*\)/.*|\2|p')

# Hint if branch name doesn't follow convention (only when TEACH_MODE is on)
if [ -z "$TYPE" ] && [ -n "$BRANCH" ] && [ "${TEACH_MODE:-off}" = "on" ]; then
  _IS_PROTECTED=false
  IFS='|' read -ra _PROT_LIST <<< "${PROTECTED_BRANCHES:-main}"
  for _pb in "${_PROT_LIST[@]}"; do
    [ "$BRANCH" = "$_pb" ] && _IS_PROTECTED=true
  done
  if [ "$_IS_PROTECTED" = "false" ]; then
    echo "" >&2
    echo "💡 Tip: Name branches as <type>/<description> for auto-prefill" >&2
    echo "   Example: feat/add-login, fix/null-check" >&2
    echo "" >&2
  fi
fi

# Pre-fill only if the first line is empty
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")
if [ -n "$TYPE" ] && [ -z "$FIRST_LINE" ]; then
  if [ -n "$SCOPE" ]; then
    PREFIX="$TYPE($SCOPE): "
  else
    PREFIX="$TYPE: "
  fi
  TEMP=$(mktemp) || exit 0
  trap 'rm -f "$TEMP"' EXIT
  echo "$PREFIX" > "$TEMP"
  tail -n +2 "$COMMIT_MSG_FILE" >> "$TEMP"
  mv "$TEMP" "$COMMIT_MSG_FILE"
  trap - EXIT
fi

exit 0
