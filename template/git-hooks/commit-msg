#!/bin/bash
# Git Shit: Commit-msg hook
# Enforces conventional commit prefixes
# Modes: strict (block) | warn (suggest) | off (skip)

# --- Config + libs ---
_gs_root="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -f "$_gs_root/.gitshitrc" ] && bash -n "$_gs_root/.gitshitrc" 2>/dev/null && . "$_gs_root/.gitshitrc"
for _d in "$_gs_root/scripts/lib" "$_gs_root/lib"; do
  [ -f "$_d/profile.sh" ] && . "$_d/profile.sh"
  [ -f "$_d/output.sh" ] && . "$_d/output.sh"
done
type gs_teach >/dev/null 2>&1 || gs_teach() { [ "${TEACH_MODE:-off}" = "on" ] && printf '%s\n' "$@"; }

COMMIT_MSG_MODE="${GIT_SHIT_COMMIT_MSG:-${COMMIT_MSG_MODE:-off}}"

# Skip entirely if turned off
[ "$COMMIT_MSG_MODE" = "off" ] && exit 0

MSG_FILE="$1"
[ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ] && exit 0

MSG=$(head -1 "$MSG_FILE")

# Allow merge/squash/fixup commits
echo "$MSG" | grep -qE '^Merge ' && exit 0
echo "$MSG" | grep -qE '^\S+.*\(#[0-9]+\)$' && exit 0
echo "$MSG" | grep -qE '^(fixup|squash)! ' && exit 0

# Check for conventional commit prefix
if echo "$MSG" | grep -qE '^(feat|fix|refactor|docs|test|chore|style|perf|ci|build|revert|research)(\([a-zA-Z0-9_-]+\))?!?: .+'; then
  exit 0
fi

# Doesn't conform — emit message (warn or strict)
echo ""
if [ "$COMMIT_MSG_MODE" = "strict" ]; then
  echo "🛑 Commit message rejected — missing conventional prefix"
else
  echo "💡 Commit message suggestion — consider using a conventional prefix"
fi
echo ""
echo "  Your message:  $MSG"
echo ""
echo "  Required format: <type>(<scope>): <description>"
echo ""
gs_teach "  Types: feat fix refactor docs test chore style perf ci build revert research" \
         "  Scope: optional — e.g., feat(auth): or fix(api):" \
         "" \
         "  Examples:" \
         "    feat: add user authentication flow" \
         "    fix(api): prevent crash on empty response" \
         "    docs: update contributing guide" \
         ""

if [ "$COMMIT_MSG_MODE" = "strict" ]; then
  gs_teach "  Tip: the commit was not created. Re-run with a valid prefix:" \
           "    git commit -m \"feat: your description here\"" \
           ""
  exit 1
fi

exit 0
