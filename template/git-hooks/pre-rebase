#!/bin/bash
# Git Shit: pre-rebase hook
# Prevents rebasing commits that have already been pushed to a remote.
# Protects shared history from accidental rewriting.

# --- Config + libs ---
_gs_root="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -f "$_gs_root/.gitshitrc" ] && bash -n "$_gs_root/.gitshitrc" 2>/dev/null && . "$_gs_root/.gitshitrc"
for _d in "$_gs_root/scripts/lib" "$_gs_root/lib"; do
  [ -f "$_d/profile.sh" ] && . "$_d/profile.sh"
  [ -f "$_d/output.sh" ] && . "$_d/output.sh"
done
type gs_teach >/dev/null 2>&1 || gs_teach() { [ "${TEACH_MODE:-off}" = "on" ] && printf '%s\n' "$@"; }

UPSTREAM="$1"
BRANCH="$2"

# Default to current branch if not specified
[ -z "$BRANCH" ] && BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
# Skip if detached HEAD
[ -z "$BRANCH" ] && exit 0

# Skip if no remote tracking (local-only branch is always safe to rebase)
REMOTE_REF=$(git rev-parse --verify "origin/$BRANCH" 2>/dev/null)
[ -z "$REMOTE_REF" ] && exit 0

LOCAL_REF=$(git rev-parse "$BRANCH" 2>/dev/null)
[ "$LOCAL_REF" = "$REMOTE_REF" ] && exit 0

# Local has unpushed commits — check if remote also diverged
PUSHED_COMMITS=$(git log --oneline "origin/$BRANCH..$BRANCH" 2>/dev/null | wc -l | tr -d ' ')

if [ "$PUSHED_COMMITS" -gt 0 ]; then
  REMOTE_ONLY=$(git log --oneline "$BRANCH..origin/$BRANCH" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$REMOTE_ONLY" -gt 0 ]; then
    echo ""
    echo "⚠️  Rebase warning: origin/$BRANCH has diverged"
    gs_teach "" \
             "  Your branch and the remote have both changed." \
             "  Rebasing may rewrite commits others have seen." \
             "" \
             "  YOUR OPTIONS:" \
             "    git pull --rebase origin $BRANCH   # replay your work on top of theirs" \
             "    git merge origin/$BRANCH           # merge both timelines (preserves history)" \
             ""
    # Warning only — don't block
  fi
  exit 0
fi

# Check if any commits to rewrite exist on the remote
WOULD_REWRITE=$(git log --oneline "$UPSTREAM..$BRANCH" 2>/dev/null)
[ -z "$WOULD_REWRITE" ] && exit 0

SHARED_COUNT=0
while IFS= read -r line; do
  SHA=$(echo "$line" | awk '{print $1}')
  if git branch -r --contains "$SHA" 2>/dev/null | grep -q "origin/$BRANCH"; then
    SHARED_COUNT=$((SHARED_COUNT + 1))
  fi
done <<< "$WOULD_REWRITE"

if [ "$SHARED_COUNT" -gt 0 ]; then
  echo ""
  echo "🛑 Rebase blocked — $SHARED_COUNT commit(s) already pushed to origin/$BRANCH"
  echo ""
  echo "  Rebasing pushed commits rewrites shared history."
  echo ""
  gs_teach "  THE DECISION:" \
           "    Pushed AND others use this branch?" \
           "      -> git merge $UPSTREAM           (preserves shared history)" \
           "    Pushed but only YOU use this branch?" \
           "      -> git push --force-with-lease   (safer than --force)" \
           "" \
           "  Golden Rule: Never rebase commits others have based work on." \
           ""
  echo "  Bypass (solo branch, force-push planned):"
  echo "    git rebase $UPSTREAM --no-verify"
  echo ""
  exit 1
fi

exit 0
